{
  "name": "bilibili-quality-filter",
  "version": "0.1.0",
  "description": "Filter low-quality content on Bilibili including rage bait, clickbait, and toxic comments",
  "private": true,
  "scripts": {
    "build": "node scripts/build.js",
    "build:prod": "NODE_ENV=production node scripts/build.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "node --test",
    "clean": "rm -rf dist/",
    "package": "npm run clean && npm run build:prod && node scripts/package.js",
    "dev": "node scripts/watch.js"
  },
  "devDependencies": {
    "archiver": "^6.0.1",
    "chokidar": "^3.5.3",
    "esbuild": "^0.27.4",
    "fs-extra": "^11.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "bilibili",
    "filter",
    "content-filter",
    "browser-extension",
    "chrome-extension"
  ],
  "author": "BQF Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/bilibili-quality-filter.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/bilibili-quality-filter/issues"
  },
  "homepage": "https://github.com/yourusername/bilibili-quality-filter#readme"
}
